# Copy this file to .env and fill in your values
# On Render: set these in Dashboard → Environment Variables

# MongoDB Atlas connection string (required for cloud deployment)
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/shophere

# Razorpay payment keys
RAZORPAY_KEY_ID=rzp_live_xxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxx

# Port (Render sets this automatically, leave as is)
PORT=8080

# Your custom domain (used to redirect away from onrender.com URLs)
CUSTOM_DOMAIN=shophere.in

# Cloudinary — free image hosting so images survive Render redeployments
# Sign up free at https://cloudinary.com → Dashboard → copy Cloud Name
# Settings → Upload → Add upload preset → set to Unsigned → copy preset name
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_UPLOAD_PRESET=shophere_uploads
